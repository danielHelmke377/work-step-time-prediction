# ── Data ──────────────────────────────────────────────────────────────────────
# Raw data belongs in cloud storage / DVC — not committed to git
data/
*.json

# ── Generated artefacts (reproducible from code) ──────────────────────────────
model_plots/
eda_plots/
gbert_base/model_plots/
*.npy

# ── Trained model pickles (use model registry or GitHub Release assets) ────────
models/*.pkl
gbert_base/models/*.pkl

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Temporary script outputs ───────────────────────────────────────────────────
text/*.txt

# ── Environment config ────────────────────────────────────────────────────────
.env
.env.local
